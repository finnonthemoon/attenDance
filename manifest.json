{
  "manifest_version": 3,
  "name": "Attendance Helper",
  "version": "1.1",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.sheffield.ac.uk/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}